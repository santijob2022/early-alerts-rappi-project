# ─────────────────────────────────────────────────────────────────
# EarlyAlertsAPI – environment template
#
#   cp .env.example .env
#   Edit .env with your values.
#   .env is gitignored and never committed.
#
# All EARLY_ALERTS_* vars override app/backend/data/config.yaml.
# Nested keys use double-underscore: EARLY_ALERTS_STORAGE__SQLITE_PATH
# ─────────────────────────────────────────────────────────────────


# ── Docker Compose misc ──────────────────────────────────────────
# Host port that the API container binds to.
API_HOST_PORT=8000
# Host port for the sqlite-web browser UI.
SQLITE_WEB_PORT=8081
# Password for the sqlite-web browser UI (default: admin).
SQLITE_WEB_PASSWORD=admin


# ── Core ─────────────────────────────────────────────────────────
EARLY_ALERTS_CITY=monterrey
EARLY_ALERTS_TIMEZONE=America/Monterrey


# ── Scheduler toggle ─────────────────────────────────────────────
# Do NOT set to true here – docker-compose.yml sets it per-service.
# Override only if running outside Docker with the API + scheduler
# in the same process (single-worker dev mode).
# EARLY_ALERTS_ENABLE_SCHEDULER=false


# ── Storage paths ────────────────────────────────────────────────
# Set in docker-compose.yml via environment: block (mapped to /data/).
# Override here only if running outside Docker.
# EARLY_ALERTS_STORAGE__SQLITE_PATH=data/alerts.db
# EARLY_ALERTS_STORAGE__DUCKDB_PATH=data/forecast_warehouse.duckdb


# ── Open-Meteo provider ──────────────────────────────────────────
EARLY_ALERTS_PROVIDER__TIMEOUT_SECONDS=30
EARLY_ALERTS_PROVIDER__MAX_RETRIES=2


# ── Polling intervals (minutes) ──────────────────────────────────
EARLY_ALERTS_POLLING__DEFAULT_INTERVAL_MINUTES=60
EARLY_ALERTS_POLLING__ELEVATED_INTERVAL_MINUTES=15


# ── Module 3 outbox ──────────────────────────────────────────────
EARLY_ALERTS_MODULE3__OUTBOX_ENABLED=true


# ── Earnings baseline ────────────────────────────────────────────
EARLY_ALERTS_EARNINGS_BASELINE_MXN=55.6
