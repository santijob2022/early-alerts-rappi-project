# ── Telegram ─────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# The chat_id where alert messages will be sent
# Run @userinfobot or check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your-chat-id-here

# ── LLM — LiteLLM format ─────────────────────────────────────────────────────
# Model string in LiteLLM format. Examples:
#   OpenAI:    gpt-4o-mini
#   Anthropic: anthropic/claude-3-haiku-20240307
#   Ollama:    ollama/llama3  (set LLM_API_BASE=http://localhost:11434)
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...your-api-key-here
# LLM_API_BASE=  # optional: custom endpoint for Azure / Ollama

# ── EarlyAlertsAPI ────────────────────────────────────────────────────────────
ALERTS_API_BASE_URL=http://localhost:8000
POLL_INTERVAL_SECONDS=120

# ── Display preferences ──────────────────────────────────────────────────────
# IANA timezone for timestamps shown in Telegram messages.
# Examples: America/Mexico_City, America/New_York, Europe/Madrid, UTC
DISPLAY_TIMEZONE=America/Mexico_City

# ── Context source paths (optional — override defaults if data moves) ─────────
# Motor_Reglas_y_Alertas.md: full calibration detail (thresholds, lifts, stats) — injected into LLM system prompt
# MOTOR_RULES_PATH=data/historical_context/Motor_Reglas_y_Alertas.md
# Documentacion_Motor_Alertas_Tempranas.md: compact operational summary — appended after rules
# MOTOR_DOCS_PATH=data/historical_context/Documentacion_Motor_Alertas_Tempranas.md
